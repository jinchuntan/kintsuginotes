# Kintsugi Notes - Environment Variables
# Copy this file to .env.local and fill in your values

# App Configuration
NEXT_PUBLIC_APP_NAME=Kintsugi Notes

# AI Configuration (Optional - app works without these using mock data)
# Supported providers: groq (recommended, free), openai, anthropic
# Get a free Groq key at: https://console.groq.com
AI_PROVIDER=groq
AI_API_KEY=
